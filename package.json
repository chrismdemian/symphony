{
  "name": "symphony",
  "version": "0.0.0",
  "description": "Claude Code orchestrator — manages multiple claude -p workers across projects from a single terminal.",
  "type": "module",
  "bin": {
    "symphony": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "build:packages": "pnpm -r --filter \"!symphony\" run build",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:packages": "pnpm -r --filter \"!symphony\" run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scenarios": "vitest run --config vitest.scenarios.config.ts",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:scenarios && pnpm build && pnpm build:packages && pnpm typecheck:packages",
    "gen:fragments": "tsx scripts/gen-prompt-fragments.ts",
    "format": "prettier --write .",
    "visual:3b1": "node tests/visual/run.mjs tests/visual/3b1-frames.tsx",
    "visual:3b2": "node tests/visual/run.mjs tests/visual/3b2-frames.tsx",
    "visual:3b3": "node tests/visual/run.mjs tests/visual/3b3-frames.tsx",
    "visual:3c": "node tests/visual/run.mjs tests/visual/3c-frames.tsx",
    "visual:3d1": "node tests/visual/run.mjs tests/visual/3d1-frames.tsx",
    "visual:3d2": "node tests/visual/run.mjs tests/visual/3d2-frames.tsx",
    "visual:3e": "node tests/visual/run.mjs tests/visual/3e-frames.tsx",
    "visual:3f1": "node tests/visual/run.mjs tests/visual/3f1-frames.tsx",
    "visual:3f3": "node tests/visual/run.mjs tests/visual/3f3-frames.tsx",
    "visual:3f4": "node tests/visual/run.mjs tests/visual/3f4-frames.tsx",
    "visual:3f2": "node tests/visual/run.mjs tests/visual/3f2-frames.tsx",
    "visual:3h1": "node tests/visual/run.mjs tests/visual/3h1-frames.tsx",
    "visual:3h2": "node tests/visual/run.mjs tests/visual/3h2-frames.tsx",
    "visual:3h3": "node tests/visual/run.mjs tests/visual/3h3-frames.tsx",
    "visual:3h4": "node tests/visual/run.mjs tests/visual/3h4-frames.tsx",
    "visual:3i": "node tests/visual/run.mjs tests/visual/3i-frames.tsx",
    "visual:3j": "node tests/visual/run.mjs tests/visual/3j-frames.tsx",
    "visual:3k": "node tests/visual/run.mjs tests/visual/3k-frames.tsx",
    "visual:3l": "node tests/visual/run.mjs tests/visual/3l-frames.tsx",
    "visual:3m": "node tests/visual/run.mjs tests/visual/3m-frames.tsx",
    "visual:3n2": "node tests/visual/run.mjs tests/visual/3n2-frames.tsx",
    "visual:3n3": "node tests/visual/run.mjs tests/visual/3n3-frames.tsx",
    "visual:3o1": "node tests/visual/run.mjs tests/visual/3o1-frames.tsx",
    "visual:3p": "node tests/visual/run.mjs tests/visual/3p-frames.tsx",
    "visual:3q": "node tests/visual/run.mjs tests/visual/3q-frames.tsx",
    "visual:3s": "node tests/visual/run.mjs tests/visual/3s-frames.tsx",
    "visual:3t": "node tests/visual/run.mjs tests/visual/3t-frames.tsx",
    "visual:3r": "node tests/visual/run.mjs tests/visual/3r-frames.tsx",
    "visual:4e": "node tests/visual/run.mjs tests/visual/4e-frames.tsx",
    "visual:6e1": "node tests/visual/run.mjs tests/visual/6e1-frames.tsx",
    "visual:6e2": "node tests/visual/run.mjs tests/visual/6e2-frames.tsx",
    "visual:6e3": "node tests/visual/run.mjs tests/visual/6e3-frames.tsx",
    "visual:7c": "node tests/visual/run.mjs tests/visual/7c-frames.tsx",
    "smoke:3b3": "node tests/smoke/3b3-pty-smoke.mjs",
    "smoke:3s": "node tests/smoke/3s-pty-smoke.mjs",
    "smoke:3r": "node tests/smoke/3r-pty-smoke.mjs",
    "smoke:4e": "node tests/smoke/4e-pty-smoke.mjs",
    "smoke:4f1": "node tests/smoke/4f1-fence-smoke.mjs",
    "smoke:6e1": "node tests/smoke/6e1-pty-smoke.mjs",
    "smoke:6e2": "node tests/smoke/6e2-pty-smoke.mjs",
    "smoke:6e3": "node tests/smoke/6e3-pty-smoke.mjs",
    "smoke:7c": "node tests/smoke/7c-pty-smoke.mjs"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@json-render/ink": "0.18.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@notionhq/client": "^5.22.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "figures": "^6.1.0",
    "fuzzysort": "^3.1.0",
    "gradient-string": "^3.0.0",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.1",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.5",
    "playwright": "^1.60.0",
    "react": "^19.2.5",
    "simple-git": "^3.36.0",
    "strip-ansi": "^7.2.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lydell/node-pty": "1.2.0-beta.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "@json-render/ink>ink": "^7.0.0"
      }
    }
  }
}
