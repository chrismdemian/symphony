{
  "name": "symphony",
  "version": "0.0.0",
  "description": "Claude Code orchestrator — manages multiple claude -p workers across projects from a single terminal.",
  "type": "module",
  "bin": {
    "symphony": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scenarios": "vitest run --config vitest.scenarios.config.ts",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:scenarios && pnpm build",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.5",
    "react": "^19.2.5",
    "simple-git": "^3.36.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
